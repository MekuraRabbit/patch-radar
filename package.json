{
  "name": "patch-radar",
  "version": "0.1.0",
  "description": "Read-only discovery of useful patch work in forks and branches.",
  "type": "module",
  "bin": {
    "patch-radar": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "github",
    "cli",
    "maintenance",
    "forks",
    "patches"
  ],
  "author": "",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^4.1.9"
  }
}
